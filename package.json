{
  "name": "@dnd-mapp/dnd-mapp",
  "version": "0.1.0",
  "description": "The official core web application for the D&D Mapp ecosystem. A containerized Angular-based game engine featuring automated 5e mechanical resolution, real-time tactical combat, and unified campaign management.",
  "license": "MIT",
  "author": "NoNamer777",
  "private": true,
  "scripts": {
    "ng": "pnpm exec ng",
    "gen:ssl-certs": "mkcert -cert-file ssl-cert.pem -key-file ssl-key.pem localhost.www.dndmapp.dev localhost 127.0.0.1",
    "test:install-browsers": "pnpm exec playwright install chromium",
    "start": "pnpm exec ng serve",
    "build": "pnpm exec ng build",
    "docker:build": "docker build -f .docker/Dockerfile -t dndmapp/dnd-mapp:latest .",
    "docker:bake": "docker buildx bake -f .docker/bake.hcl app",
    "docker:compose:up": "docker compose -f .docker/compose.yaml up -d",
    "docker:compose:down": "docker compose -f .docker/compose.yaml down",
    "test": "pnpm exec ng test",
    "test:development": "pnpm exec ng test -c development",
    "format:check": "pnpm exec prettier -l .",
    "format:write": "pnpm exec prettier -w .",
    "lint": "pnpm lint:eslint && pnpm lint:stylelint && pnpm lint:markdownlint",
    "lint:eslint": "pnpm exec ng lint",
    "lint:stylelint": "pnpm exec stylelint \"**/*.scss\"",
    "lint:markdownlint": "pnpm exec markdownlint \"**/*.md\""
  },
  "packageManager": "pnpm@10.33.0",
  "engines": {
    "node": "~24.14"
  },
  "devEngines": {
    "runtime": {
      "name": "node",
      "version": "~24.14",
      "onFail": "error"
    },
    "packageManager": [
      {
        "name": "pnpm",
        "version": "10.33.0",
        "onFail": "error"
      }
    ]
  },
  "dependencies": {
    "@angular/cdk": "~21.2",
    "@angular/common": "~21.2",
    "@angular/compiler": "~21.2",
    "@angular/core": "~21.2",
    "@angular/forms": "~21.2",
    "@angular/platform-browser": "~21.2",
    "@angular/router": "~21.2",
    "@dnd-mapp/shared-utils": "~1.2",
    "rxjs": "~7.8",
    "tslib": "~2.8"
  },
  "devDependencies": {
    "@angular-eslint/builder": "~21.3",
    "@angular/build": "~21.2",
    "@angular/cli": "~21.2",
    "@angular/compiler-cli": "~21.2",
    "@eslint/js": "~10.0",
    "@types/node": "~24.12",
    "@vitest/browser-playwright": "~4.1",
    "@vitest/coverage-v8": "~4.1",
    "@vitest/ui": "~4.1",
    "angular-eslint": "~21.3",
    "eslint": "~10.1",
    "eslint-config-prettier": "~10.1",
    "globals": "~17.4",
    "markdownlint": "~0.40",
    "markdownlint-cli": "~0.48.0",
    "playwright": "~1.58",
    "prettier": "~3.8",
    "prettier-plugin-organize-imports": "~4.3",
    "stylelint": "~17.6",
    "stylelint-config-clean-order": "~8.0",
    "stylelint-config-standard-scss": "~17.0",
    "stylelint-order": "~8.1",
    "typescript": "~5.9",
    "typescript-eslint": "~8.57",
    "vite": "~8.0",
    "vitest": "~4.1"
  }
}
