{
    "$schema": "./node_modules/@angular/cli/lib/config/schema.json",
    "version": 1,
    "cli": {
        "packageManager": "pnpm",
        "analytics": "b0c115ec-2ab3-4894-8de9-af5d5c82733d",
        "schematicCollections": ["angular-eslint"]
    },
    "newProjectRoot": "projects",
    "projects": {
        "dnd-mapp": {
            "projectType": "application",
            "root": "",
            "sourceRoot": "src",
            "prefix": "dma",
            "architect": {
                "build": {
                    "builder": "@angular/build:application",
                    "options": {
                        "allowedCommonJsDependencies": [],
                        "assets": [
                            {
                                "glob": "**/*",
                                "input": "public"
                            }
                        ],
                        "browser": "src/main.ts",
                        "inlineStyleLanguage": "scss",
                        "security": {
                            "allowedHosts": ["localhost.www.dndmapp.dev:4200"],
                            "autoCsp": true
                        },
                        "styles": ["src/styles.scss"],
                        "tsConfig": "tsconfig.app.json"
                    },
                    "defaultConfiguration": "production",
                    "configurations": {
                        "production": {
                            "budgets": [
                                {
                                    "type": "initial",
                                    "maximumWarning": "500kB",
                                    "maximumError": "1MB"
                                },
                                {
                                    "type": "anyComponentStyle",
                                    "maximumWarning": "4kB",
                                    "maximumError": "8kB"
                                }
                            ],
                            "outputHashing": "all",
                            "subresourceIntegrity": true
                        },
                        "development": {
                            "extractLicenses": false,
                            "namedChunks": true,
                            "optimization": false,
                            "sourceMap": true,
                            "watch": true
                        }
                    }
                },
                "serve": {
                    "builder": "@angular/build:dev-server",
                    "options": {
                        "allowedHosts": ["localhost.www.dndmapp.dev:4200"],
                        "buildTarget": "dnd-mapp:build:development",
                        "host": "localhost.www.dndmapp.dev",
                        "ssl": true,
                        "sslCert": "ssl-cert.pem",
                        "sslKey": "ssl-key.pem"
                    }
                },
                "test": {
                    "builder": "@angular/build:unit-test",
                    "options": {
                        "coverage": true,
                        "coverageExclude": ["**/index.ts", "**/config/**/*.ts", "src/main.ts"],
                        "coverageInclude": ["src/app/**/*.ts"],
                        "coverageReporters": [
                            "text-summary",
                            [
                                "html",
                                {
                                    "subdir": "coverage"
                                }
                            ]
                        ],
                        "include": ["src/**/*.spec.ts"],
                        "runner": "vitest",
                        "runnerConfig": "vitest.config.mts",
                        "tsConfig": "tsconfig.spec.json"
                    },
                    "defaultConfiguration": "ci",
                    "configurations": {
                        "ci": {
                            "reporters": [
                                "dot",
                                "github-actions",
                                [
                                    "html",
                                    {
                                        "outputFile": "coverage/dnd-mapp/index.html"
                                    }
                                ]
                            ],
                            "watch": false
                        },
                        "development": {
                            "reporters": [
                                "dot",
                                [
                                    "html",
                                    {
                                        "outputFile": "reports/dnd-mapp/index.html"
                                    }
                                ]
                            ],
                            "ui": true,
                            "watch": true
                        }
                    }
                },
                "lint": {
                    "builder": "@angular-eslint/builder:lint",
                    "options": {
                        "cache": true,
                        "lintFilePatterns": ["src/**/*.ts", "src/**/*.html"]
                    }
                }
            }
        }
    },
    "schematics": {
        "@schematics/angular:component": {
            "addTypeToClassName": true,
            "changeDetection": "OnPush",
            "style": "scss",
            "type": "component"
        },
        "@schematics/angular:directive": {
            "addTypeToClassName": true,
            "type": "directive"
        },
        "@schematics/angular:guard": {
            "typeSeparator": "."
        },
        "@schematics/angular:interceptor": {
            "typeSeparator": "."
        },
        "@schematics/angular:pipe": {
            "typeSeparator": "."
        },
        "@schematics/angular:resolver": {
            "typeSeparator": "."
        },
        "@schematics/angular:service": {
            "type": "service",
            "addTypeToClassName": true
        }
    }
}
